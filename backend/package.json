{
  "name": "matcha-backend",
  "version": "1.0.0",
  "description": "Authentication backend for Matcha dating app",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
