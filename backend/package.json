    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "nodemailer": "^6.9.7",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "cookie-parser": "^1.4.6",
